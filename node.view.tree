					text <= row_text* \
					syntax <= syntax null
					uri_resolve* <= uri_resolve* \
					highlight <= highlight \
		<= Copy $mol_button_copy
			hint @ \Copy whole code
			text <= text_export \

$mol_textarea $mol_stack
	attr *
		^
		mol_textarea_clickable <= clickable? false
		mol_textarea_sidebar_showed <= sidebar_showed false
	event *
		keydown?event <=> press?event null
		pointermove?event <=> hover?event null
	sub /
		<= Edit $mol_textarea_edit
			value? <=> value? \
			hint <= hint \ 
			enabled <= enabled true
			spellcheck <= spellcheck true
			length_max <= length_max +Infinity
			selection? <=> selection? /number
			bring => bring
			submit? <=> submit? null
			submit_with_ctrl <= submit_with_ctrl true
		<= View $mol_text_code
			text <= value
			render_visible_only false
			row_numb* <= row_numb* 0
			sidebar_showed <= sidebar_showed
			highlight <= highlight \
			syntax <= syntax $mol_syntax2
	symbols_alt *string
		comma \<
		period \>
		dash \−
		equals \≈
		graveAccent \́
		forwardSlash \÷
		E \€
		V \✔
		X \×
		C \©
		P \§
		H \₽
		key0 \°
		key8 \•
		key2 \@
		key3 \#
		key4 \$
		key6 \^
		key7 \&
		bracketOpen \[
		bracketClose \]
		slashBack \|
	symbols_alt_ctrl *string
		space \ 
	symbols_alt_shift *string
		V \✅
		X \❌
		O \⭕
		key1 \❗
		key4 \💲
		key7 \❓
		comma \«
		period \»
		semicolon \“
		quoteSingle \”
		dash \—
		equals \≠
		graveAccent \̱
		bracketOpen \{
		bracketClose \}

$mol_textarea_edit $mol_string
	dom_name \textarea
	enter \enter
	field *
		^
		scrollTop 0

$bog_call_host $mol_view
	peer null
	store null
	on_back? null
	on_connected? null
	frames_share /string
	scan_status \
	scan_error \
	manual_visible? false
	manual_text? \
	toggle_manual? null
	apply_manual? null
	on_scan_decode? \
	sub /
		<= Header $mol_view
			sub /
				<= Back $mol_button_minor
					click? <=> on_back?
					sub /
						<= back_label @ \Назад
				<= Title $mol_view
					sub /
						<= title @ \Звонок: ваш QR
		<= Body $mol_view
			sub /
				<= Show $bog_call_qr_show
					frames <= frames_share
				<= Step_label $mol_view
					sub /
						<= step_label @ \Теперь сканируйте QR гостя
				<= Scanner $bog_call_qr_scan
					on_decode <=> on_scan_decode?
				<= Status $mol_view
					sub /
						<= scan_status
				<= Error $mol_view
					sub /
						<= scan_error
				<= Manual_toggle $mol_button_minor
					click? <=> toggle_manual?
					sub /
						<= manual_label @ \Ввести вручную
				<= Manual $mol_view
					sub /
						<= Manual_input $mol_textarea
							hint @ \Вставьте текст QR гостя
							value? <=> manual_text?
						<= Apply $mol_button_major
							click? <=> apply_manual?
							sub /
								<= apply_label @ \Применить

$bog_call_guest $mol_view
	peer null
	store null
	on_back? null
	on_connected? null
	frames_answer /string
	scan_status \
	scan_error \
	manual_visible? false
	manual_text? \
	toggle_manual? null
	apply_manual? null
	on_scan_decode? \
	answer_ready false
	sub /
		<= Header $mol_view
			sub /
				<= Back $mol_button_minor
					click? <=> on_back?
					sub /
						<= back_label @ \Назад
				<= Title $mol_view
					sub /
						<= title @ \Звонок: сканирование
		<= Body $mol_view
			sub <= body_sub /
		<= Scan_block $mol_view
			sub /
				<= Step_a $mol_view
					sub /
						<= step_a @ \Шаг 1. Сканируйте QR хоста
				<= Scanner $bog_call_qr_scan
					on_decode <=> on_scan_decode?
				<= Status $mol_view
					sub /
						<= scan_status
				<= Error $mol_view
					sub /
						<= scan_error
				<= Manual_toggle $mol_button_minor
					click? <=> toggle_manual?
					sub /
						<= manual_label @ \Ввести вручную
				<= Manual $mol_view
					sub /
						<= Manual_input $mol_textarea
							hint @ \Вставьте текст QR хоста
							value? <=> manual_text?
						<= Apply $mol_button_major
							click? <=> apply_manual?
							sub /
								<= apply_label @ \Применить
		<= Share_block $mol_view
			sub /
				<= Step_b $mol_view
					sub /
						<= step_b @ \Шаг 2. Покажите QR хосту
				<= Show $bog_call_qr_show
					frames <= frames_answer

$bog_call_active $mol_view
	peer null
	on_hangup? null
	hangup? null
	mute? false
	connection_label \
	quality_label \
	auto /
		<= wake null
	sub /
		<= Indicator $mol_view
			attr *
				^
				quality <= quality \good
			sub /
				<= indicator_label \●
		<= Status $mol_view
			sub /
				<= connection_label
		<= Quality $mol_view
			sub /
				<= quality_label
		<= Mute $mol_check
			title @ \Микрофон выключен
			checked? <=> mute?
		<= Hangup $mol_button_major
			click? <=> hangup?
			sub /
				<= hangup_label @ \Завершить

$bog_call_app $mol_page
	title @ \Локальный звонок
	name? \
	open_host? null
	open_guest? null
	goto_home? null
	goto_active? null
	tools /
		<= Sources $mol_link_source
			uri \https://github.com/bog/call
		<= Status $giper_baza_status
		<= Theme_toggle $bog_theme_toggle
			theme_auto <= Theme
	plugins /
		<= Theme $bog_theme_auto
			theme_light \$mol_theme_calm_light
			theme_dark \$mol_theme_calm_dark
			themes /
				\$mol_theme_calm_light
				\$mol_theme_calm_dark
	body <= screen_body /
	Menu $bog_call_menu
		name? <=> name?
		host_click? <=> open_host? null
		guest_click? <=> open_guest? null
	Host $bog_call_host
		peer <= peer null
		store <= store null
		on_back? <=> goto_home? null
		on_connected? <=> goto_active? null
	Guest $bog_call_guest
		peer <= peer
		store <= store
		on_back? <=> goto_home?
		on_connected? <=> goto_active?
	Active $bog_call_active
		peer <= peer
		on_hangup? <=> goto_home?
